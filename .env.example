# === Chatwoot ===
CHATWOOT_URL=https://support.example.com
CHATWOOT_BOT_TOKEN=your_agent_bot_token_here
CHATWOOT_ACCOUNT_ID=1

# === Security ===
WEBHOOK_SECRET=change_me_to_a_random_string
ADMIN_SECRET=change_me_to_another_random_string
ALLOWED_ORIGINS=https://support.example.com

# === LLM Provider ===
# Options: gemini, openai, anthropic
LLM_PROVIDER=gemini
LLM_API_KEY=your_api_key_here
LLM_MODEL=gemini-2.0-flash

# For OpenAI-compatible endpoints (optional)
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# === Bot Identity ===
COMPANY_NAME=Your Company
ASSISTANT_NAME=Support Assistant

# === Database (pgvector) ===
DATABASE_URL=postgresql://postgres:password@localhost:5432/wootbot

# === Bot Behavior ===
CONFIDENCE_THRESHOLD=0.65
MAX_CONTEXT_MESSAGES=10
BOT_LANGUAGE=es
HANDOFF_MESSAGE=Te transfiero con un agente humano. Un momento por favor.
GREETING_MESSAGE=Hola! Soy el asistente de soporte. En que puedo ayudarte?

# === Email Formatting (auto-translated by LLM to customer's language) ===
EMAIL_GREETING=Hola, gracias por contactar con nosotros.
EMAIL_CLOSING=Esperamos haber sido de ayuda. Si necesitas cualquier otra cosa, estaremos encantados de ayudarte.\nUn cordial saludo,\nEquipo de Soporte

# === Document Ingestion ===
CHUNK_SIZE=500
CHUNK_OVERLAP=50
