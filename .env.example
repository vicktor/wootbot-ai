# === Chatwoot ===
CHATWOOT_URL=https://support.listen.doctor
CHATWOOT_BOT_TOKEN=your_agent_bot_token_here
CHATWOOT_ACCOUNT_ID=1

# === LLM Provider ===
# Options: gemini, openai, anthropic
LLM_PROVIDER=gemini
LLM_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-2.0-flash

# For OpenAI-compatible endpoints (optional)
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# === Database (pgvector) ===
DATABASE_URL=postgresql://postgres:password@localhost:5432/wootbot

# === Bot Behavior ===
CONFIDENCE_THRESHOLD=0.65
MAX_CONTEXT_MESSAGES=10
BOT_LANGUAGE=es
HANDOFF_MESSAGE=Te transfiero con un agente humano. Un momento por favor.
GREETING_MESSAGE=¡Hola! Soy el asistente de soporte. ¿En qué puedo ayudarte?

# === Document Ingestion ===
CHUNK_SIZE=500
CHUNK_OVERLAP=50
